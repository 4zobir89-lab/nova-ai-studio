{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Task",
  "description": "A unit of work in the Nova AI Studio workflow",
  "type": "object",
  "required": ["id", "title", "owner", "status"],
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique task identifier"
    },
    "title": {
      "type": "string",
      "description": "Task title"
    },
    "description": {
      "type": "string",
      "description": "Detailed task description"
    },
    "owner": {
      "type": "string",
      "description": "Agent responsible for this task"
    },
    "priority": {
      "type": "string",
      "enum": ["critical", "high", "medium", "low"],
      "default": "medium"
    },
    "status": {
      "type": "string",
      "enum": ["pending", "in-progress", "review", "completed", "failed", "fix-required"],
      "default": "pending"
    },
    "input": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Input artifact references"
    },
    "output": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Expected output artifacts"
    },
    "reviewer": {
      "type": "string",
      "description": "Agent responsible for reviewing output"
    },
    "dependencies": {
      "type": "array",
      "items": { "type": "string", "format": "uuid" },
      "description": "Task IDs that must complete first"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "completedAt": {
      "type": "string",
      "format": "date-time"
    }
  }
}
